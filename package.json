{
  "name": "tazeai-monorepo",
  "private": true,
  "homepage": "https://tazeai.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/tazeai/tazeai"
  },
  "license": "Apache-2.0",
  "scripts": {
    "build": "turbo build --filter=\"./packages/**\"",
    "bump-ui": "pnpx shadcn@canary add --all --overwrite -c packages/ui && pnpm format",
    "changeset": "changeset",
    "clean": "turbo run clean --parallel",
    "coverage": "vitest --coverage",
    "dev": "NODE_ENV=development turbo dev --parallel --filter=\"./apps/website\"",
    "format": "biome format --write",
    "generate": "turbo gen",
    "postinstall": "manypkg fix",
    "lint": "biome check",
    "prepare": "husky",
    "start": "turbo run start --filter=\"./apps/*\"",
    "test": "vitest",
    "update": "pnpm update -r"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json}": [
      "pnpm format"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.29.0",
    "@manypkg/cli": "^0.23.0",
    "@turbo/gen": "^2.5.0",
    "@types/fs-extra": "^11.0.4",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "catalog:",
    "dotenv-cli": "^8.0.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.1",
    "lodash-es": "^4.17.21",
    "pathe": "^2.0.3",
    "picocolors": "^1.1.1",
    "rimraf": "^6.0.1",
    "turbo": "^2.5.0",
    "type-fest": "^4.40.0",
    "typescript": "catalog:",
    "vitest": "^3.1.1"
  },
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": "^20 || >=22",
    "pnpm": ">=9.10.0"
  }
}
